package rmi;
import java.rmi.*;
import java.awt.*;
import java.awt.event.*;

public class MathClient extends Frame implements ActionListener {

    TextField t1 = new TextField();
    TextField t2 = new TextField();
    TextField t3 = new TextField();

    Button add = new Button("Add");
    Button sub = new Button("Sub");
    Button mul = new Button("Mul");
    Button div = new Button("Div");

    public MathClient() {
        setLayout(null);

        t1.setBounds(100, 50, 100, 30);
        t2.setBounds(100, 100, 100, 30);
        t3.setBounds(100, 150, 100, 30);

        add.setBounds(50, 200, 50, 30);
        sub.setBounds(110, 200, 50, 30);
        mul.setBounds(170, 200, 50, 30);
        div.setBounds(230, 200, 50, 30);

        add(t1); add(t2); add(t3);
        add(add); add(sub); add(mul); add(div);

        add.addActionListener(this);
        sub.addActionListener(this);
        mul.addActionListener(this);
        div.addActionListener(this);

        setSize(350, 300);
        setVisible(true);

        addWindowListener(new WindowAdapter() {
            public void windowClosing(WindowEvent e) {
                System.exit(0);
            }
        });
    }

    public void actionPerformed(ActionEvent e) {
        try {
            MathInterface obj = (MathInterface) Naming.lookup("rmi://localhost/calc");

            int a = Integer.parseInt(t1.getText());
            int b = Integer.parseInt(t2.getText());
            int result = 0;

            if (e.getSource() == add)
                result = obj.add(a, b);
            else if (e.getSource() == sub)
                result = obj.sub(a, b);
            else if (e.getSource() == mul)
                result = obj.mul(a, b);
            else if (e.getSource() == div)
                result = obj.div(a, b);

            t3.setText("" + result);

        } catch (Exception ex) {
            System.out.println(ex);
        }
    }

    public static void main(String args[]) {
        new MathClient();
    }
}
